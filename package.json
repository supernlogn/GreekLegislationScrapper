{
  "name": "greeklegislation",
  "version": "1.0.0",
  "description": "Scraper for the Greek Government Gazette legislation catalogue (search.et.gr). Downloads PDFs for any year and tracks new publications daily.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "scrape:table": "tsx scripts/exportListingTable.ts",
    "scrape:all": "tsx scripts/scrapeAllYears.ts",
    "check:new": "tsx scripts/checkNewLegislation.ts"
  },
  "keywords": [
    "greek",
    "legislation",
    "scraper",
    "playwright",
    "pdf"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  }
}
